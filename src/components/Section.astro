---
const { title, content, bannerImageUrl, children } = Astro.props;
---

<section
  class="snap-center snap-normal min-h-screen max-w-[calc(100%-2rem)] flex flex-col justify-center w-full"
>
  <h2
    class="bg-gradient-to-r from-primary via-primary to-cyan-500 bg-clip-text text-4xl tracking-tighter text-transparent"
  >
    {title}
  </h2>
  {
    bannerImageUrl && (
      <img
        src={bannerImageUrl}
        alt="Banner Image"
        class="w-full h-64 object-cover object-center my-4"
      />
    )
  }
  <div class="section-content text-secondary-foreground">
    {content}
  </div>
  <div class="">
    <slot />
  </div>
</section>
